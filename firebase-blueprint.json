{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A table booking at the snooker club.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the booking."
        },
        "name": {
          "type": "string",
          "description": "Full name of the person booking."
        },
        "date": {
          "type": "string",
          "description": "Date of the booking (YYYY-MM-DD)."
        },
        "time": {
          "type": "string",
          "description": "Time of the booking (HH:MM)."
        },
        "tableId": {
          "type": "string",
          "description": "The ID or name of the table booked."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "cancelled"],
          "description": "Status of the booking."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the booking was created."
        }
      },
      "required": ["userId", "name", "date", "time", "tableId", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "bio": {
          "type": "string",
          "description": "A short bio."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "User role for authorization."
        },
        "updatedAt": {
          "type": "timestamp",
          "description": "When the profile was last updated."
        }
      },
      "required": ["uid", "displayName", "email"]
    },
    "TournamentRegistration": {
      "title": "TournamentRegistration",
      "description": "A registration for a tournament.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user registering."
        },
        "tournamentName": {
          "type": "string",
          "description": "The name of the tournament."
        },
        "name": {
          "type": "string",
          "description": "Full name of the registrant."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the registrant."
        },
        "membershipId": {
          "type": "string",
          "description": "Optional membership ID."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "Status of the registration."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the registration was created."
        }
      },
      "required": ["userId", "tournamentName", "name", "email", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/bookings/{bookingId}": {
      "schema": {
        "$ref": "#/entities/Booking"
      },
      "description": "Stores all table bookings."
    },
    "/tournamentRegistrations/{registrationId}": {
      "schema": {
        "$ref": "#/entities/TournamentRegistration"
      },
      "description": "Stores tournament registrations."
    }
  }
}
